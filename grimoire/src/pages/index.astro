---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---


	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="text-4xl font-semibold mb-2">{SITE_TITLE}</h1>
			<p class="text-lg text-gray-700 mb-12">Technical Designer | Producer</p>
			
			<section class="grid gap-6 sm:grid-cols-3">
				<a href="/project" class="bg-brand-green text-brand-greye px-6 py-8 rounded-lg shadow-lg hover:bg-green-700 transition transform hover:-translate-y-1 hover:scale-105 text-left">
					<h2 class="text-2xl font-semibold mb-2">Projects</h2>
					<p class="text-gray-200">Check out my work.</p>
				</a>

				<a href="/blog" class="bg-brand-green text-brand-grey px-6 py-8 rounded-lg shadow-lg hover:bg-green-700 transition transform hover:-translate-y-1 hover:scale-105 text-left">
					<h2 class="text-2xl font-semibold mb-2">Blog</h2>
					<p class="text-gray-200">Read my blog.</p>
				</a>

				<a href="/about" class="bg-brand-green text-brand-grey px-6 py-8 rounded-lg shadow-lg hover:bg-green-700 transition transform hover:-translate-y-1 hover:scale-105 text-left">
					<h2 class="text-2xl font-semibold mb-2">About Me</h2>
					<p class="text-gray-200">Learn more about my journey.</p>
				</a>
			</section>
		</main>
		<Footer />
	</body>
